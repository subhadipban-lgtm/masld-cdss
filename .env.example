# MASLD DrugScope Environment Configuration
# Copy this file to .env and fill in the values

# === Application ===
PIPELINE_VERSION=1.0.0
MODEL_VERSION=v1.0.0-production
LOG_LEVEL=INFO

# === Redis (Celery broker & result backend) ===
REDIS_URL=redis://localhost:6379/0

# === PostgreSQL (job metadata & audit trail) ===
POSTGRES_PASSWORD=masld_dev_2024
DATABASE_URL=postgresql://masld:masld_dev_2024@localhost:5432/masld_drugscope

# === Reference Data ===
REFERENCE_DATA_DIR=/app/reference_data
GENCODE_VERSION=44
SALMON_INDEX_DIR=/app/reference_data/salmon_index
MODEL_WEIGHTS_PATH=/app/reference_data/models/graphsage_v1.pt
KG_EDGE_LIST_PATH=/app/reference_data/kg/edge_list.tsv
NORMALIZATION_STATS_PATH=/app/reference_data/models/normalization_stats.json

# === Upload Limits ===
MAX_UPLOAD_SIZE_MB=500
UPLOAD_CLEANUP_HOURS=24

# === Tool Paths (auto-detected if empty) ===
FASTQC_PATH=
FASTP_PATH=
SALMON_PATH=